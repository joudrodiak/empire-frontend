NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side Next.js proxy target. Docker Compose overrides this to
# `http://api:4000`; production should use the deployed API origin.
INTERNAL_API_URL=http://localhost:4000
# CDK outputs; reserved for switching the frontend auth adapter to Cognito.
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
